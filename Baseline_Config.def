
# ==================================
# CFD settings Radial Compressor MHI
# ==================================

# Number of outer iterations
CFD.Control.NIteration = 2500 #500

# Writing solution interval (0 = No intermediate output)
CFD.Control.WriteSolutionInterval = 200

# Writing convergence history interval (0 = No output)
CFD.Control.WriteConvergenceInterval = 1

# Convergence criteria of the density residual
CFD.Control.ConvergenceCriteria = 1.0e-8

# Multigrid strategy in i/j/k direction (1 1 1 - single grid)
CFD.Control.MGStrategy = 2 2 2

# Multigrid Cycle (0 = V-cycle, 1 = W-cycle)
CFD.Control.MGCycle = 0

# Multigrid Pre-Smoothing iterations on every grid level
CFD.Control.MGPreSmoothIteration = 0 1

# Multigrid Post-Smoothing iterations on every grid level
CFD.Control.MGPostSmoothIteration = 1 0

# Relaxation coefficient for the multigrid residual restriction (0-1)
CFD.Control.MGRestrictionRelaxation = 1.0

# Relaxation coefficient for the multigrid prolongation (0-1)
CFD.Control.MGProlongationRelaxation = 1.0

# Use coarse grid initialization, i.e. Full Multigrid (FMG)
CFD.Control.FMGInitialization = true

# Number of iterations on every grid level of the FMG
CFD.Control.FMGNIteration = 250	

# Convergence criteria of the density residual on every grid level of the FMG
CFD.Control.FMGConvergenceCriteria = 1.0e-12

# Convergence level of max. Density residual at which LHS system matrix is freezed
CFD.Control.JacobianFreezingCriteria = 1.0e-6

CFD.Control.ExportYPlus = true

# ==============
# Physical Model
# ==============

# Fluid Model
# ===========

# Type: PerfectGas
CFD.PhysicalModel.FluidModel.Type = PerfectGas

CFD.PhysicalModel.FluidModel.Gamma = 1.4
CFD.PhysicalModel.FluidModel.GasConstant = 287.0
CFD.PhysicalModel.FluidModel.PrandtlNumberLaminar = 0.72
CFD.PhysicalModel.FluidModel.PrandtlNumberTurbulent = 0.9

# Flow Model
# ==========

# Type: Euler, Laminar, Turbulent
#--------------------------------

CFD.PhysicalModel.FlowModel.Type = Turbulent

CFD.PhysicalModel.FlowModel.ReferencePressure = 101325.00
CFD.PhysicalModel.FlowModel.ReferenceTemperature = 293.15
CFD.PhysicalModel.FlowModel.ReferenceLength = 0.0316 # Impeller radius
CFD.PhysicalModel.FlowModel.RPM = 150000.0

# Gradient type: FullNS = 0, ThinLayer = 1
#-----------------------------------------
CFD.PhysicalModel.FlowModel.GradientType = 0

# Turbulence Model
# ================

# Type: None, SA
#----------------
CFD.PhysicalModel.TurbulenceModel.Type = SA

# Boundary Conditions
# ===================

# 1. Inlet
#=========

# Type: Supersonic, Subsonic
#--------------------------- 
CFD.PhysicalModel.BoundaryCondition.Inlet.Type = Subsonic

# Specify total pressure or mass flow
#------------------------------------ 
CFD.PhysicalModel.BoundaryCondition.Inlet.TotalPressureSpecified = true

CFD.PhysicalModel.BoundaryCondition.Inlet.TotalPressure.Type=Constant
CFD.PhysicalModel.BoundaryCondition.Inlet.TotalPressure.Constant.Value = 97098.0

CFD.PhysicalModel.BoundaryCondition.Inlet.TotalTemperature.Type = Constant
CFD.PhysicalModel.BoundaryCondition.Inlet.TotalTemperature.Constant.Value = 303


CFD.PhysicalModel.BoundaryCondition.Inlet.CoordinateSystem = Cylindrical 

# Type: Constant or Profile
CFD.PhysicalModel.BoundaryCondition.Inlet.VelocityVector.Type = Constant

CFD.PhysicalModel.BoundaryCondition.Inlet.VelocityVector.Constant.Value = 1 0 0 # Vx/V, Vr/V, Vt/V
     
CFD.PhysicalModel.TurbulenceModel.SA.MuTildeRatio_Inlet = 3.0 # fully turbulent

# 2. Outlet
#==========     
     
# Type: Supersonic, Subsonic 
#---------------------------
CFD.PhysicalModel.BoundaryCondition.Outlet.Type = Subsonic  
   
# Specify pressure or mass flow    
CFD.PhysicalModel.BoundaryCondition.Outlet.PressureSpecified = true 

CFD.PhysicalModel.BoundaryCondition.Outlet.ReferenceValue = 301000.00

CFD.PhysicalModel.BoundaryCondition.Outlet.PressureInitialGuess = 301000.0 # Initial guess of the outlet static pressure if mass flow option is used

CFD.PhysicalModel.BoundaryCondition.Outlet.CoordinateSystem = Cylindrical
CFD.PhysicalModel.BoundaryCondition.Outlet.RadialEquilibrium = false
CFD.PhysicalModel.BoundaryCondition.Outlet.ReferencePressureLocation = hub


# 3. Viscous walls
#=================
 
CFD.PhysicalModel.BoundaryCondition.AreaDefinedRPM.Radius.Min = 0.0
CFD.PhysicalModel.BoundaryCondition.AreaDefinedRPM.Radius.Max = 0.032
CFD.PhysicalModel.BoundaryCondition.AreaDefinedRPM.X.Min = -0.025
CFD.PhysicalModel.BoundaryCondition.AreaDefinedRPM.X.Max = 0.001

CFD.PhysicalModel.BoundaryCondition.AreaDefinedRPM.RotatingShroud = false

# Initial solution
# ================

# Flow solution

CFD.PhysicalModel.InitialSolution.FlowSpecified = true

# Type: Constant, File
CFD.PhysicalModel.InitialSolution.Flow.Type = Constant

CFD.PhysicalModel.InitialSolution.Flow.Constant.StaticPressure = 97098.00 #97098.0
CFD.PhysicalModel.InitialSolution.Flow.Constant.StaticTemperature = 457.3
CFD.PhysicalModel.InitialSolution.Flow.Constant.Vx = 10.00 #10.00
CFD.PhysicalModel.InitialSolution.Flow.Constant.Vy = 5.00 #5.00
CFD.PhysicalModel.InitialSolution.Flow.Constant.Vz = 5.00 #5.00



# SA-Model: Mu-Tilde/Mu
CFD.PhysicalModel.InitialSolution.Flow.Constant.MuTildeRatio = 3.0 # fully turbulent

CFD.PhysicalModel.InitialSolution.Flow.FileName = /students/2025/willems/Documents/CADO_SOFTWARE/sem2case/FlowSolution2/RadialCompressor.cgns #get file from srv2 initial solution

# Adjoint solution

CFD.PhysicalModel.InitialSolution.AdjointSpecified = true

# Type: Constant, File
CFD.PhysicalModel.InitialSolution.Adjoint.Type = Constant 

# File containing initial adjoint solution when "File" option is used. 
# Converged flow solution is supposed to be in cgns passed as argument to main program.

CFD.PhysicalModel.InitialSolution.Adjoint.FileName = /students/2025/willems/Documents/CADO_SOFTWARE/sem2case/AdjointSolution/RadialCompressor.cgns


# =============
# Cost function
# =============

# 1) entropy generation
# 2) mass flow
# 3) exit flow angle (in Cartesian or Cylindrical coord.)
# 4) total-to-static isentropic efficiency
# 5) total-to-total pressure ratio
# 6) total pressure loss coefficient  
# 7) power 

CFD.CostFunctionSpecified = true

CFD.CostFunction.FunctionIndex = 8
CFD.CostFunction.ReferenceValue = 0.75

# ===============
# Numerical Model
# ===============

# Spatial discretization
# ======================

# Type: Upwind, Central
CFD.NumericalModel.SpatialDiscretisation.Type = Upwind

# Order: 1,2
CFD.NumericalModel.SpatialDiscretisation.Order = 2

# Upwind

# Type: Roe, RoeTurkel
CFD.NumericalModel.SpatialDiscretisation.Upwind.Type = Roe

# Scaling parameter of Harten's entropy correction
CFD.NumericalModel.SpatialDiscretisation.Upwind.EntropyFix = 0.15 0.15 0.15

# MUSCL scheme: Fromm, UpwindBiased, FullyUpwind, Unlimited
CFD.NumericalModel.SpatialDiscretisation.Upwind.MUSCL.Type = Fromm

# Parameter to scale the numerical threshold value for the MUSCL extrapolation
CFD.NumericalModel.SpatialDiscretisation.Upwind.MUSCL.LimiterConstant = 1.0e-3


# Central

# Type: JST
CFD.NumericalModel.SpatialDiscretisation.Central.Type = JST

CFD.NumericalModel.SpatialDiscretisation.Central.K2 = 0.5
CFD.NumericalModel.SpatialDiscretisation.Central.K4 = 0.1
CFD.NumericalModel.SpatialDiscretisation.Central.MaxLinearArtDiss = 0.3
CFD.NumericalModel.SpatialDiscretisation.Central.MaxNonLinearArtDiss = 0.4 


# Temporal discretization
# =======================

# Type: Implicit, Explicit
CFD.NumericalModel.TemporalDiscretisation.Type = Implicit

# Multi-stage Runge-Kutta coefficients

CFD.NumericalModel.TemporalDiscretisation.RKStageCoefficient = 0.1918 0.4929 1.0     
 

# Implicit

# Linear solver: GMRES,BICGSTAB
CFD.NumericalModel.TemporalDiscretisation.Implicit.Type = GMRES

CFD.NumericalModel.TemporalDiscretisation.Implicit.RelativeTolerance = 1.0e-2
CFD.NumericalModel.TemporalDiscretisation.Implicit.AbsoluteTolerance = 1.0e-16
CFD.NumericalModel.TemporalDiscretisation.Implicit.MaxIteration = 1000
CFD.NumericalModel.TemporalDiscretisation.Implicit.NRestartGMRES = 50

# CFL Number

CFD.NumericalModel.TemporalDiscretisation.Implicit.CFL.CFLAdaptive = false

CFD.NumericalModel.TemporalDiscretisation.Implicit.CFL.Min = 1
CFD.NumericalModel.TemporalDiscretisation.Implicit.CFL.Max = 25
CFD.NumericalModel.TemporalDiscretisation.Implicit.CFL.NIteration = 1500




